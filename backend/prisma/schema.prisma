generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserProfile {
  id              String           @id @default(cuid())
  persona         String
  walkMinutes     Int
  companionType   String?
  interestTags    String[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  recommendations Recommendation[]
  adminCase       AdminCase?
}

model Recommendation {
  id            String      @id @default(cuid())
  profileId     String
  profile       UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  primaryAction String
  summary       String
  shareMessage  String
  createdAt     DateTime    @default(now())
}

model AdminCase {
  id                   String         @id @default(cuid())
  profileId            String?        @unique
  profile              UserProfile?   @relation(fields: [profileId], references: [id], onDelete: SetNull)
  name                 String
  ageLabel             String
  district             String
  riskLevel            String
  workflowStatus       String         @default("pending")
  lastParticipationDays Int
  preferredTime        String
  mobilitySummary      String
  nextRecommendation   String
  statusTags           String[]
  histories            AdminHistory[]
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
}

model AdminHistory {
  id         String    @id @default(cuid())
  caseId      String
  adminCase   AdminCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  type       String
  summary    String
  createdAt  DateTime  @default(now())
}
